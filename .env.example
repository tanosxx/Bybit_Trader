# Bybit API (v5) - DEMO Trading
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=false
BYBIT_BASE_URL=https://api-demo.bybit.com  # Demo режим

# Database
DATABASE_URL=postgresql+asyncpg://bybit_user:bybit_secure_pass_2024@postgres_bybit:5432/bybit_trader

# AI APIs - Gemini (3 ключа для ротации)
GOOGLE_API_KEY_1=your_google_api_key_1
GOOGLE_API_KEY_2=your_google_api_key_2
GOOGLE_API_KEY_3=your_google_api_key_3

# AI APIs - OpenRouter (резервный)
OPENROUTER_API_KEY=your_openrouter_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# News API (CryptoPanic) - для фундаментального анализа
# Получить бесплатный ключ: https://cryptopanic.com/developers/api/
# Лимит: 100 req/month на ключ, используй несколько аккаунтов!
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_1
CRYPTOPANIC_API_KEY_2=your_cryptopanic_api_key_2
CRYPTOPANIC_API_KEY_3=your_cryptopanic_api_key_3

# Strategic Brain - Claude 3.5 Sonnet через OhMyGPT (бонусный баланс)
# Определяет глобальный рыночный режим раз в 4 часа
OHMYGPT_KEY=your_ohmygpt_api_key_here
STRATEGIC_DRIVER_URL=https://apic1.ohmycdn.com/api/v1/ai/openai/cc-omg/
STRATEGIC_MODEL=claude-3-5-sonnet-20240620

# Algion (GPTFree) - Fallback для Gemini при исчерпании лимитов
# Бесплатный API для GPT моделей: https://algion.dev
# Получить токен: зарегистрируйтесь на сайте и создайте API key
ALGION_BEARER_TOKEN=your_algion_bearer_token_here

# Trading Settings
INITIAL_BALANCE=50.0
SCAN_INTERVAL=60  # секунд (1 минута)
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS=5.0  # $5 (10% от баланса)
